# Pinia Stores

## Structure
```typescript
import { defineStore } from 'pinia'

export const useExampleStore = defineStore('example', {
  state: () => ({
    // Prefer flat structures for simple reactivity
    // For nested objects: use getters and explicit actions
  }),

  getters: {
    // Getters for derived values and reactivity with nested data
    myValue(): Type {
      return this.nested.property
    }
  },

  actions: {
    // Explicit actions for mutations
    updateValue(value: Type) {
      this.nested.property = value
      this.save() // If persistence is needed
    }
  }
})
```

## Reactivity with Nested Objects

### Problem
Nested objects (e.g., `state.editor.showGrid`) can cause reactivity issues when:
- `storeToRefs()` is applied to nested properties
- Computed properties don't track correctly

### Solution 1: Use Getters
```typescript
// In Store
getters: {
  showGrid(): boolean {
    return this.editor.showGrid
  }
}

// In Component with storeToRefs
const { showGrid } = storeToRefs(store)
```

### Solution 2: Reference $state explicitly
```typescript
// In Component
const showGrid = computed(() => store.$state.editor.showGrid)
```

### Solution 3: Explicit Toggle Actions
```typescript
// In Store
actions: {
  toggleShowGrid() {
    this.editor.showGrid = !this.editor.showGrid
    this.save()
  }
}

// In Component
store.toggleShowGrid()
```

## Vue-Konva Specifics

Avoid `v-if` with vue-konva, use Konva's native `visible` property instead:

```vue
<!-- Not reactive with v-if -->
<v-layer v-if="showGrid">

<!-- Better: visible property via computed -->
<v-layer :config="gridLayerConfig">

<script setup>
const gridLayerConfig = computed(() => ({
  visible: showGrid.value
}))
</script>
```

## Persistence
```typescript
actions: {
  save() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(this.$state))
  },
  load() {
    const saved = localStorage.getItem(STORAGE_KEY)
    if (saved) this.$patch(JSON.parse(saved))
  }
}
```
